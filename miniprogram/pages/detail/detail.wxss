.container {
  padding: 24rpx;
}

.info-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.plant-photo {
  width: 100%;
  height: 400rpx;
  border-radius: 12rpx;
  margin-bottom: 24rpx;
}

.info-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.plant-name {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
}

.plant-category {
  font-size: 24rpx;
  color: #999;
  background: #f0f0f0;
  padding: 6rpx 20rpx;
  border-radius: 8rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.info-label {
  font-size: 28rpx;
  color: #999;
}

.info-value {
  font-size: 28rpx;
  color: #333;
}

.info-value.note {
  flex: 1;
  margin-left: 24rpx;
  text-align: right;
  white-space: pre-wrap;
}

.actions {
  display: flex;
  gap: 16rpx;
  margin-bottom: 32rpx;
}

.action-btn {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  border-radius: 12rpx;
  font-size: 28rpx;
}

.water-btn {
  background: #e3f2fd;
  color: #1565c0;
}

.edit-btn {
  background: #e8f5e9;
  color: #2e7d32;
}

.delete-btn {
  background: #ffebee;
  color: #c62828;
}

.action-btn:active {
  opacity: 0.7;
}

.records-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
  display: block;
}

.empty-records {
  text-align: center;
  padding: 40rpx;
  color: #999;
  font-size: 26rpx;
}

.record-item {
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.record-item:last-child {
  border-bottom: none;
}

.record-time {
  font-size: 26rpx;
  color: #666;
}
