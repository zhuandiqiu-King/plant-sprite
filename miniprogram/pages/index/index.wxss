.container {
  padding: 24rpx;
  padding-bottom: 160rpx;
  background: #f5f7fa;
  min-height: 100vh;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
  margin-top: 16rpx;
}

.plant-list-title {
  margin-top: 24rpx;
}

/* ---- 浇水清单 ---- */
.reminder-section {
  background: linear-gradient(135deg, #fff8e1, #fff3e0);
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  border-left: 8rpx solid #ff9800;
}

.reminder-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.reminder-section .section-title {
  margin: 0;
  color: #e65100;
  font-size: 30rpx;
}

.water-all-btn {
  background: #ff9800;
  color: #fff;
  font-size: 24rpx;
  padding: 8rpx 24rpx;
  border-radius: 24rpx;
  font-weight: bold;
}

.water-all-btn:active {
  opacity: 0.8;
}

.reminder-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.reminder-item {
  background: #fff;
  border-radius: 16rpx;
  padding: 16rpx 20rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.reminder-left {
  display: flex;
  align-items: center;
  flex: 1;
  min-width: 0;
}

.reminder-photo {
  width: 80rpx;
  height: 80rpx;
  border-radius: 12rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.reminder-photo-placeholder {
  width: 80rpx;
  height: 80rpx;
  border-radius: 12rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
  background: #e8f5e9;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
}

.reminder-info {
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.reminder-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.reminder-interval {
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
}

.water-btn {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #42a5f5, #1e88e5);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  flex-shrink: 0;
  margin-left: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(30, 136, 229, 0.3);
}

.water-btn:active {
  transform: scale(0.9);
}

/* ---- 全部浇完提示 ---- */
.all-done {
  background: linear-gradient(135deg, #e8f5e9, #c8e6c9);
  border-radius: 20rpx;
  padding: 24rpx;
  text-align: center;
  font-size: 28rpx;
  color: #2e7d32;
  margin-bottom: 16rpx;
  border-left: 8rpx solid #4caf50;
}

/* ---- 空状态 ---- */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 200rpx;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

/* ---- FAB ---- */
.fab {
  position: fixed;
  right: 40rpx;
  bottom: 80rpx;
  width: 100rpx;
  height: 100rpx;
  line-height: 100rpx;
  text-align: center;
  background: linear-gradient(135deg, #66bb6a, #43a047);
  color: #fff;
  font-size: 56rpx;
  border-radius: 50%;
  box-shadow: 0 6rpx 20rpx rgba(7, 193, 96, 0.4);
}

.fab:active {
  transform: scale(0.95);
}
