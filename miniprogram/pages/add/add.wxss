.container {
  padding: 24rpx;
}

.identify-btn {
  background: #e8f5e9;
  color: #2e7d32;
  text-align: center;
  padding: 24rpx;
  border-radius: 16rpx;
  margin-bottom: 32rpx;
  font-size: 30rpx;
}

.identify-btn:active {
  background: #c8e6c9;
}

/* 照片选择区域 */
.photo-section {
  margin-bottom: 32rpx;
}

.photo-picker {
  width: 200rpx;
  height: 200rpx;
  border: 2rpx dashed #ccc;
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #fafafa;
}

.photo-picker:active {
  background: #f0f0f0;
}

.photo-add-icon {
  font-size: 64rpx;
  color: #999;
  line-height: 1;
}

.photo-add-text {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

.photo-preview {
  position: relative;
  width: 200rpx;
  height: 200rpx;
}

.photo-img {
  width: 200rpx;
  height: 200rpx;
  border-radius: 16rpx;
}

.photo-remove {
  position: absolute;
  top: -16rpx;
  right: -16rpx;
  width: 40rpx;
  height: 40rpx;
  background: rgba(0, 0, 0, 0.5);
  color: #fff;
  border-radius: 50%;
  text-align: center;
  line-height: 40rpx;
  font-size: 28rpx;
}

.form {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 32rpx;
}

.form-item {
  margin-bottom: 24rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.label {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 8rpx;
  display: block;
}

.input {
  border: 1rpx solid #e0e0e0;
  border-radius: 8rpx;
  padding: 16rpx;
  font-size: 28rpx;
}

.picker {
  border: 1rpx solid #e0e0e0;
  border-radius: 8rpx;
  padding: 16rpx;
  font-size: 28rpx;
  color: #333;
}

.textarea {
  border: 1rpx solid #e0e0e0;
  border-radius: 8rpx;
  padding: 16rpx;
  font-size: 28rpx;
  width: 100%;
  box-sizing: border-box;
}

.submit-btn {
  margin-top: 16rpx;
}
