.profile-page {
  min-height: 100vh;
  background: #F5F0EB;
  padding-bottom: 40rpx;
}

/* 头像区域 */
.user-header {
  background: #fff;
  padding: 60rpx 0 40rpx;
  text-align: center;
  position: relative;
  overflow: hidden;
}

.header-deco {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 8rpx;
  background: linear-gradient(90deg, #2ECC71, #3498DB);
}

.avatar-wrap {
  margin: 0 auto 20rpx;
}

.user-avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  border: 4rpx solid #A8E6CF;
  box-shadow: 0 4rpx 16rpx rgba(46, 204, 113, 0.15);
}

.avatar-placeholder {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #E8F8F0, #A8E6CF);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 64rpx;
  margin: 0 auto;
}

.user-name {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #2C3E50;
}

.user-tag {
  display: inline-block;
  margin-top: 12rpx;
  font-size: 22rpx;
  color: #2ECC71;
  background: #E8F8F0;
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
}

/* 分区 */
.section {
  margin: 24rpx;
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.section-title {
  font-size: 26rpx;
  color: #95A5A6;
  padding: 24rpx 28rpx 12rpx;
  font-weight: bold;
}

/* 设置项 */
.setting-item {
  display: flex;
  align-items: center;
  padding: 28rpx;
  border-bottom: 1rpx solid #F5F5F5;
}

.setting-item:last-child {
  border-bottom: none;
}

.item-icon {
  width: 52rpx;
  height: 52rpx;
  line-height: 52rpx;
  text-align: center;
  border-radius: 12rpx;
  font-size: 24rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.icon-style { background: #E8F8F0; }
.icon-char { background: #FFF8E1; }
.icon-nick { background: #FDEDEB; }
.icon-edit { background: #E8F0FE; }
.icon-about { background: #F3E8FD; }

.item-label {
  font-size: 28rpx;
  color: #2C3E50;
  flex: 1;
}

.item-value {
  display: flex;
  align-items: center;
  font-size: 26rpx;
  color: #95A5A6;
}

.arrow {
  font-size: 32rpx;
  color: #BDC3C7;
  margin-left: 12rpx;
}

/* 称呼输入 */
.nickname-input {
  flex: 1;
  text-align: right;
  font-size: 26rpx;
  color: #95A5A6;
}

/* 自定义角色输入 */
.custom-input-wrap {
  padding: 0 28rpx 24rpx;
}

.custom-input {
  width: 100%;
  height: 72rpx;
  padding: 0 20rpx;
  background: #F8F9FA;
  border-radius: 16rpx;
  font-size: 26rpx;
}

/* 退出登录 */
.logout-section {
  margin-top: 40rpx;
}

.logout-item {
  justify-content: center;
}

.logout-item .item-label {
  color: #E74C3C;
  flex: none;
  font-weight: 500;
}

/* 保存按钮 */
.save-btn-wrap {
  padding: 20rpx 28rpx 28rpx;
}

.save-btn {
  width: 100%;
  height: 84rpx;
  line-height: 84rpx;
  background: linear-gradient(135deg, #2ECC71, #27AE60);
  color: #fff;
  font-size: 30rpx;
  border-radius: 42rpx;
  border: none;
  box-shadow: 0 4rpx 16rpx rgba(46, 204, 113, 0.25);
}

.save-btn:active {
  opacity: 0.85;
  transform: scale(0.98);
}
