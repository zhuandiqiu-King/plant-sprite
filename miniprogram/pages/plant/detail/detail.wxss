.container {
  padding: 24rpx;
  padding-top: 0;
  background: #F5F0EB;
  min-height: 100vh;
}

.info-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 0;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
  overflow: hidden;
}

.plant-photo {
  width: 100%;
  height: 400rpx;
  display: block;
}

.info-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  padding: 28rpx 28rpx 20rpx;
  border-bottom: 1rpx solid #F5F5F5;
}

.plant-name {
  font-size: 40rpx;
  font-weight: bold;
  color: #2C3E50;
}

.plant-category {
  font-size: 24rpx;
  color: #2ECC71;
  background: #E8F8F0;
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  margin-bottom: 16rpx;
  padding: 0 28rpx;
}

.info-row:last-child {
  padding-bottom: 28rpx;
}

.info-label {
  font-size: 28rpx;
  color: #95A5A6;
}

.info-value {
  font-size: 28rpx;
  color: #2C3E50;
}

.info-value.note {
  flex: 1;
  margin-left: 24rpx;
  text-align: right;
  white-space: pre-wrap;
}

/* 操作按钮 */
.actions {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
  padding: 0 24rpx;
}

.action-btn {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  border-radius: 20rpx;
  font-size: 28rpx;
  background: #fff;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
  font-weight: 500;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.water-btn {
  color: #3498DB;
}

.edit-btn {
  color: #2ECC71;
}

.delete-btn {
  color: #E74C3C;
}

.action-btn:active {
  opacity: 0.7;
  transform: scale(0.96);
}

/* 浇水记录 */
.records-section {
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx;
  margin: 0 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #2C3E50;
  margin-bottom: 16rpx;
  display: block;
}

.empty-records {
  text-align: center;
  padding: 40rpx;
  color: #95A5A6;
  font-size: 26rpx;
}

.record-item {
  padding: 16rpx 0 16rpx 20rpx;
  border-bottom: 1rpx solid #F5F5F5;
  border-left: 4rpx solid #3498DB;
  margin-bottom: 4rpx;
}

.record-item:last-child {
  border-bottom: none;
}

.record-time {
  font-size: 26rpx;
  color: #95A5A6;
}
