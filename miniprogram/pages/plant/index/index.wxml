<view class="container">
  <!-- 顶部问候 -->
  <view class="greeting-area">
    <text class="greeting-text">Hello 🌿</text>
    <text class="greeting-sub">照顾好你的植物朋友们</text>
  </view>

  <!-- 浇水清单 -->
  <view class="reminder-section" wx:if="{{reminders.length > 0}}">
    <view class="reminder-deco-bar"></view>
    <view class="reminder-header">
      <view class="section-title">💧 今日浇水</view>
      <view class="water-all-btn" bindtap="handleWaterAll" wx:if="{{reminders.length > 1}}">
        <text>{{watering ? '浇水中...' : '🚿 全部浇水'}}</text>
      </view>
    </view>
    <view class="reminder-list">
      <view class="reminder-item" wx:for="{{reminders}}" wx:key="id">
        <view class="reminder-left">
          <image
            wx:if="{{item.photo_url}}"
            class="reminder-photo"
            src="{{item.photo_url}}"
            mode="aspectFill"
          />
          <view wx:else class="reminder-photo-placeholder">🌱</view>
          <view class="reminder-info">
            <text class="reminder-name">{{item.name}}</text>
            <text class="reminder-interval">每{{item.watering_interval}}天 · {{item.category === 'indoor' ? '室内' : '室外'}}</text>
          </view>
        </view>
        <view
          class="water-btn"
          data-id="{{item.id}}"
          data-name="{{item.name}}"
          catchtap="handleWaterOne"
        >💧</view>
      </view>
    </view>
  </view>

  <!-- 全部浇完的提示 -->
  <view class="all-done" wx:if="{{!loading && reminders.length === 0 && plants.length > 0}}">
    <text class="all-done-icon">🌈</text>
    <text class="all-done-text">今天的植物都已浇水，真棒！</text>
  </view>

  <!-- 植物列表 -->
  <view class="section-title plant-list-title" wx:if="{{plants.length > 0}}">🌿 我的植物</view>
  <plant-card
    wx:for="{{plants}}"
    wx:key="id"
    plant="{{item}}"
    bindtap="goDetail"
  />

  <!-- 空状态 -->
  <view class="empty" wx:if="{{!loading && plants.length === 0}}">
    <text class="empty-icon">🌱</text>
    <text class="empty-title">还没有植物</text>
    <text class="empty-text">点击下方 + 按钮添加你的第一棵植物吧</text>
  </view>

  <!-- 添加按钮 (FAB) -->
  <view class="fab" bindtap="goAdd">+</view>
</view>
