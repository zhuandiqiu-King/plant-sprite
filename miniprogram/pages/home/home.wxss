.chat-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #F5F0EB;
}

/* 消息列表 */
.message-list {
  flex: 1;
  padding: 20rpx 24rpx;
  padding-bottom: 0;
}

.scroll-bottom {
  height: 20rpx;
}

/* 消息行 */
.message-row {
  display: flex;
  align-items: flex-start;
  margin-bottom: 28rpx;
}

.msg-left {
  flex-direction: row;
}

.msg-right {
  flex-direction: row-reverse;
}

/* 头像 */
.avatar {
  width: 76rpx;
  height: 76rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  flex-shrink: 0;
}

.avatar-ai {
  background: linear-gradient(135deg, #A8E6CF, #2ECC71);
  margin-right: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(46, 204, 113, 0.2);
}

.avatar-user {
  background: linear-gradient(135deg, #A8D8EA, #3498DB);
  margin-left: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(52, 152, 219, 0.2);
}

/* 气泡 */
.bubble {
  max-width: 65%;
  padding: 20rpx 28rpx;
  font-size: 28rpx;
  line-height: 1.6;
  word-break: break-all;
}

.bubble-ai {
  background: #fff;
  color: #2C3E50;
  border-radius: 4rpx 20rpx 20rpx 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.bubble-user {
  background: linear-gradient(135deg, #A8E6CF, #88D8A8);
  color: #1A5C2E;
  border-radius: 20rpx 4rpx 20rpx 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(46, 204, 113, 0.15);
}

/* 加载动画 */
.loading-bubble {
  padding: 24rpx 36rpx;
}

.dot-loading {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #2ECC71;
  animation: dotBounce 1.2s infinite ease-in-out;
}

.dot:nth-child(2) {
  animation-delay: 0.2s;
}

.dot:nth-child(3) {
  animation-delay: 0.4s;
}

@keyframes dotBounce {
  0%, 80%, 100% {
    transform: scale(0.6);
    opacity: 0.4;
  }
  40% {
    transform: scale(1);
    opacity: 1;
  }
}

/* 底部输入栏 */
.input-bar {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background: #fff;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.04);
}

/* 语音/键盘切换 */
.voice-toggle {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.msg-input {
  flex: 1;
  height: 72rpx;
  padding: 0 28rpx;
  background: #F0FAF4;
  border-radius: 36rpx;
  font-size: 28rpx;
  color: #2C3E50;
}

.send-btn {
  margin-left: 12rpx;
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: #E0E0E0;
  flex-shrink: 0;
  transition: background 0.2s;
}

.send-active {
  background: linear-gradient(135deg, #2ECC71, #27AE60);
  box-shadow: 0 4rpx 12rpx rgba(46, 204, 113, 0.3);
}

.send-icon {
  font-size: 32rpx;
  color: #fff;
}

/* 语音按钮 */
.voice-btn {
  flex: 1;
  height: 72rpx;
  line-height: 72rpx;
  text-align: center;
  font-size: 28rpx;
  color: #2C3E50;
  background: #F0FAF4;
  border-radius: 36rpx;
  font-weight: 500;
}

.voice-btn:active,
.voice-btn-active {
  background: linear-gradient(135deg, #A8E6CF, #2ECC71);
  color: #fff;
}
