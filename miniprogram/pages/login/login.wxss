.login-page {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100vh;
  background: linear-gradient(180deg, #E8F8F0 0%, #F5F0EB 50%, #FFFFFF 100%);
  position: relative;
  overflow: hidden;
}

/* 装饰背景圆 */
.login-deco-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  pointer-events: none;
}

.deco-circle {
  position: absolute;
  border-radius: 50%;
}

.deco-circle-1 {
  width: 400rpx;
  height: 400rpx;
  background: radial-gradient(circle, rgba(46, 204, 113, 0.08), transparent);
  top: -100rpx;
  right: -100rpx;
}

.deco-circle-2 {
  width: 300rpx;
  height: 300rpx;
  background: radial-gradient(circle, rgba(243, 156, 18, 0.06), transparent);
  bottom: 100rpx;
  left: -80rpx;
}

.logo-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 60rpx;
  position: relative;
  z-index: 1;
}

.logo-icon {
  font-size: 200rpx;
  margin-bottom: 16rpx;
  animation: floatUp 3s ease-in-out infinite;
}

@keyframes floatUp {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-16rpx); }
}

.logo-title {
  font-size: 48rpx;
  font-weight: bold;
  color: #2ECC71;
  letter-spacing: 4rpx;
}

.logo-desc {
  font-size: 26rpx;
  color: #95A5A6;
  margin-top: 12rpx;
}

/* 头像 + 昵称区 */
.profile-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 60rpx;
  position: relative;
  z-index: 1;
}

.avatar-btn {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  padding: 0;
  margin: 0;
  overflow: hidden;
  background: transparent;
  border: none;
  line-height: normal;
}

.avatar-btn::after {
  display: none;
}

.avatar-img {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  display: block;
  border: 4rpx solid #A8E6CF;
}

.avatar-placeholder {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: #fff;
  border: 4rpx dashed #2ECC71;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
}

.avatar-placeholder-icon {
  font-size: 40rpx;
}

.avatar-placeholder-text {
  font-size: 20rpx;
  color: #2ECC71;
  text-align: center;
}

.nickname-input {
  width: 400rpx;
  height: 72rpx;
  margin-top: 28rpx;
  padding: 0 24rpx;
  text-align: center;
  font-size: 30rpx;
  color: #2C3E50;
  background: rgba(255, 255, 255, 0.8);
  border-bottom: 3rpx solid #A8E6CF;
  border-radius: 0;
}

.login-btn {
  width: 600rpx;
  height: 96rpx;
  line-height: 96rpx;
  background: linear-gradient(135deg, #2ECC71, #27AE60);
  color: #fff;
  font-size: 34rpx;
  font-weight: 500;
  border-radius: 48rpx;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(46, 204, 113, 0.35);
  position: relative;
  z-index: 1;
  letter-spacing: 4rpx;
}

.login-btn:active {
  opacity: 0.9;
  transform: scale(0.98);
}

.login-footer {
  margin-top: 32rpx;
  font-size: 22rpx;
  color: #BDC3C7;
  position: relative;
  z-index: 1;
}
