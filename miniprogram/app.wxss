page {
  background-color: #F5F0EB;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  font-size: 28rpx;
  color: #2C3E50;
}

.container {
  padding: 24rpx;
}

/* 通用卡片 */
.section-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
  margin-bottom: 24rpx;
}

/* 主按钮 — 药丸形渐变绿 */
.btn-primary {
  background: linear-gradient(135deg, #2ECC71, #27AE60);
  color: #fff;
  border-radius: 48rpx;
  font-size: 32rpx;
  text-align: center;
  padding: 0;
  height: 88rpx;
  line-height: 88rpx;
  box-shadow: 0 4rpx 16rpx rgba(46, 204, 113, 0.3);
  border: none;
}

.btn-primary:active {
  opacity: 0.85;
  transform: scale(0.98);
}
