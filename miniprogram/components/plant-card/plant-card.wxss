.card {
  background: #fff;
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
  display: flex;
  align-items: center;
}

/* 左侧图片 — 圆形 */
.card-photo-wrap {
  flex-shrink: 0;
  margin-right: 20rpx;
}

.card-photo {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  display: block;
  border: 3rpx solid #A8E6CF;
}

.card-photo-placeholder {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #E8F8F0, #A8E6CF);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
}

/* 右侧内容 */
.card-content {
  flex: 1;
  min-width: 0;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.plant-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #2C3E50;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  flex: 1;
  margin-right: 12rpx;
}

.plant-category {
  font-size: 22rpx;
  color: #2ECC71;
  background: #E8F8F0;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  flex-shrink: 0;
}

.card-body {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.interval {
  font-size: 24rpx;
  color: #95A5A6;
}

.status {
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  flex-shrink: 0;
  font-weight: 500;
}

.status-ok {
  color: #2ECC71;
  background: #E8F8F0;
}

.status-today {
  color: #F39C12;
  background: #FFF8E1;
}

.status-overdue {
  color: #E74C3C;
  background: #FDEDEB;
}

/* 箭头 */
.card-arrow {
  font-size: 36rpx;
  color: #BDC3C7;
  margin-left: 8rpx;
  flex-shrink: 0;
}
