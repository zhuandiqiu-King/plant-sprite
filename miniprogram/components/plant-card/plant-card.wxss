.card {
  background: #fff;
  border-radius: 20rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  display: flex;
  align-items: center;
  border-left: 8rpx solid #66bb6a;
}

/* 左侧图片 */
.card-photo-wrap {
  flex-shrink: 0;
  margin-right: 20rpx;
}

.card-photo {
  width: 120rpx;
  height: 120rpx;
  border-radius: 16rpx;
  display: block;
}

.card-photo-placeholder {
  width: 120rpx;
  height: 120rpx;
  border-radius: 16rpx;
  background: linear-gradient(135deg, #e8f5e9, #c8e6c9);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 56rpx;
}

/* 右侧内容 */
.card-content {
  flex: 1;
  min-width: 0;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.plant-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  flex: 1;
  margin-right: 12rpx;
}

.plant-category {
  font-size: 22rpx;
  color: #666;
  background: #f5f5f5;
  padding: 4rpx 14rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
}

.card-body {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.interval {
  font-size: 24rpx;
  color: #888;
}

.status {
  font-size: 22rpx;
  padding: 4rpx 14rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
}

.status-ok {
  color: #2e7d32;
  background: #e8f5e9;
}

.status-today {
  color: #e65100;
  background: #fff3e0;
}

.status-overdue {
  color: #c62828;
  background: #ffebee;
}
